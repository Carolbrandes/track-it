# ======================================
# Track-it — Environment Variables
# ======================================
# Copy this file to .env and fill in the values.

# ---- JWT ----
JWT_SECRET=your_jwt_secret_here

# ---- MongoDB ----
# OBRIGATÓRIO para Docker: credenciais root do MongoDB
MONGO_INITDB_ROOT_USERNAME=trackit_admin
MONGO_INITDB_ROOT_PASSWORD=senha_forte_aqui

# String de conexão (Docker: hostname "mongo" = service name)
# authSource=admin é necessário para usuário root
MONGODB_URI=mongodb://trackit_admin:senha_forte_aqui@mongo:27017/trackit?authSource=admin

# Local / fora do Docker:
#   MONGODB_URI=mongodb://usuario:senha@localhost:27017/trackit?authSource=admin
# MongoDB Atlas:
#   MONGODB_URI=mongodb+srv://...

# ---- Backup automático (S3 / Digital Ocean Spaces) ----
# Para envio diário às 3h via cron. Crie um Space/Bucket e chaves de API.
# BACKUP_S3_BUCKET=nome-do-bucket
# AWS_ACCESS_KEY_ID=sua_access_key
# AWS_SECRET_ACCESS_KEY=sua_secret_key
# BACKUP_S3_ENDPOINT=https://sfo2.digitaloceanspaces.com   # só para DO Spaces
# BACKUP_S3_PREFIX=trackit-backups   # pasta dentro do bucket (opcional)

# ---- Email (Resend) ----
RESEND_API_KEY=re_your_api_key_here

# ---- Google Gemini AI ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- NextAuth (if needed) ----
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_nextauth_secret_here
